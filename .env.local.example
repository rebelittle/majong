# Copy this file to .env.local and fill in real values from your Supabase project
# (Project Settings → API). These are PUBLIC keys — safe to ship to the browser.
# Row-Level Security policies in the database enforce who can read/write what.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
